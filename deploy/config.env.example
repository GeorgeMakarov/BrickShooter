# /etc/brickshooter/config.env — copy this file there and tune as needed.

# Listen address. 0.0.0.0 exposes publicly; 127.0.0.1 keeps it local.
HOST=0.0.0.0
PORT=8000

# Max inbound WebSocket frame size (bytes). Client messages are tiny JSON;
# 64 KiB is generous and still caps a malicious flood.
WS_MAX_SIZE=65536

# Concurrent game cap and idle eviction (read by backend/app.py).
BRICKSHOOTER_MAX_SESSIONS=64
BRICKSHOOTER_SESSION_TTL_S=1800

# Path to the built frontend bundle the backend serves at /.
BRICKSHOOTER_FRONTEND_DIR=/opt/brickshooter/frontend
